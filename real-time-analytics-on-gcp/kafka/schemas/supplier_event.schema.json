{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.supplychain.internal/supplier_event.schema.json",
  "title": "SupplierEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "event_timestamp",
    "schema_version",
    "source_system",
    "supplier_id"
  ],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": {
      "type": "string",
      "enum": ["SUPPLIER_ONBOARDED", "SUPPLIER_PO_ISSUED", "SUPPLIER_PO_ACKNOWLEDGED", "SUPPLIER_PO_DELAYED", "SUPPLIER_RATING_UPDATED"]
    },
    "event_timestamp": { "type": "string", "format": "date-time" },
    "schema_version": { "type": "string", "const": "1.0" },
    "source_system": { "type": "string" },
    "supplier_id": { "type": "string" },
    "po_number": { "type": "string" },
    "sku_list": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expected_delivery_date": { "type": "string", "format": "date" },
    "rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    }
  }
}
