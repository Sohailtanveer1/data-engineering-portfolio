{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.supplychain.internal/order_event.schema.json",
  "title": "OrderEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "event_timestamp",
    "schema_version",
    "source_system",
    "warehouse_id",
    "order_id",
    "customer_id",
    "order_status",
    "line_items"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique per event. Used downstream as the idempotency/dedup key — replaying the same event_id must be a no-op."
    },
    "event_type": {
      "type": "string",
      "enum": ["ORDER_CREATED", "ORDER_UPDATED", "ORDER_CANCELLED", "ORDER_FULFILLED"]
    },
    "event_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the event occurred at the source (event time, not processing time)."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "source_system": {
      "type": "string",
      "description": "Originating system, e.g. WMS-EAST-01."
    },
    "warehouse_id": { "type": "string" },
    "order_id": { "type": "string" },
    "customer_id": { "type": "string" },
    "order_status": {
      "type": "string",
      "enum": ["PENDING", "CONFIRMED", "CANCELLED", "FULFILLED"]
    },
    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sku", "quantity", "unit_price"],
        "properties": {
          "sku": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 },
          "unit_price": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
